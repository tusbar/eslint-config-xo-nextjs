{
  "name": "eslint-config-xo-nextjs",
  "version": "8.0.2",
  "description": "ESLint shareable config for Next.js to be used with eslint-config-xo",
  "repository": "https://github.com/tusbar/eslint-config-xo-nextjs",
  "author": "Bertrand Marron",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "check:ts": "tsc --noEmit",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "react",
    "jsx",
    "eslintconfig",
    "xo",
    "xoxo",
    "code",
    "quality",
    "style",
    "lint",
    "linter",
    "jscs",
    "jshint",
    "jslint",
    "eslint",
    "validate",
    "code style",
    "standard",
    "strict",
    "check",
    "checker",
    "verify",
    "enforce",
    "hint",
    "simple",
    "vercel",
    "nextjs"
  ],
  "dependencies": {
    "@next/eslint-plugin-next": "^16.2.6",
    "eslint-config-xo-react": "^0.30.1"
  },
  "devDependencies": {
    "@bizon/semantic-release-config": "^3.1.0",
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.39",
    "@tsconfig/node24": "^24.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.3",
    "eslint-config-xo-bizon": "^4.3.0",
    "jest": "^30.4.2",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "xo": "^1.2.3"
  },
  "release": {
    "extends": "@bizon/semantic-release-config"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
